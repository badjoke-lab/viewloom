{
  "name": "viewloom",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev:web": "pnpm --filter @viewloom/web dev",
    "build:web": "pnpm --filter @viewloom/web build",
    "typecheck:web": "pnpm --filter @viewloom/web typecheck",
    "preview:web": "pnpm --filter @viewloom/web preview",
    "kick:seed-import:check": "node workers/collector-kick/scripts/generate-kick-seed-import-sql.mjs --check-only",
    "kick:seed-import:generate": "node workers/collector-kick/scripts/generate-kick-seed-import-sql.mjs",
    "kick:live-probe": "node workers/collector-kick/scripts/probe-kick-live-candidates.mjs",
    "kick:live-probe:fast": "node workers/collector-kick/scripts/probe-kick-live-candidates.mjs --concurrency=8 --timeout-ms=5000 --progress-every=25",
    "kick:live-probe:safe": "node workers/collector-kick/scripts/probe-kick-live-candidates.mjs --concurrency=4 --timeout-ms=10000 --progress-every=25",
    "kick:live-probe:slow": "node workers/collector-kick/scripts/probe-kick-live-candidates.mjs --concurrency=2 --timeout-ms=15000 --progress-every=25",
    "kick:live-probe:aggressive": "node workers/collector-kick/scripts/probe-kick-live-candidates.mjs --concurrency=16 --timeout-ms=2500 --progress-every=25",
    "kick:live-probe:py": "python3 workers/collector-kick/scripts/probe-kick-live-candidates-python.py --concurrency=8 --timeout=10 --progress-every=25",
    "kick:live-probe:py-safe": "python3 workers/collector-kick/scripts/probe-kick-live-candidates-python.py --concurrency=4 --timeout=12 --progress-every=25",
    "check": "npm --prefix apps/web run typecheck"
  }
}
