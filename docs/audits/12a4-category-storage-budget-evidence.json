  "candidateModels": {
    "raw_payload_only": {
      "decision": "rejected",
      "retains90DayCategoryEvidence": false,
      "preservesHourlyCategory": true,
      "twitchRawRetentionIncrementalMbWithSafety": 22.1,
      "kickRawRetentionIncrementalMbWithSafety": 13.15,
      "reason": "Raw retention remains Twitch 30 days and Kick 60 days, so raw-only storage cannot support the 90-day foundation without an unauthorized retention extension."
    },
    "dominant_daily": {
      "decision": "rejected",
      "retains90DayCategoryEvidence": true,
      "preservesHourlyCategory": false,
      "twitchLongTermIncrementalMb90dWithSafety": 4.04,
      "kickLongTermIncrementalMb90dWithSafety": 1.45,
      "reason": "One category per streamer/day irreversibly loses time-of-day category changes."
    },
    "embedded_hourly": {
      "decision": "selected",
      "retains90DayCategoryEvidence": true,
      "preservesHourlyCategory": true,
      "twitchLongTermIncrementalMb90dWithSafety": 26.22,
      "kickLongTermIncrementalMb90dWithSafety": 8.86,
      "reason": "Compact hourly evidence fits existing streamer/day rows without multiplying row count or adding a category index before Phase 15."
    },
    "separate_hourly_table": {
      "decision": "rejected",
      "retains90DayCategoryEvidence": true,
      "preservesHourlyCategory": true,
      "twitchLongTermIncrementalMb90dWithSafety": 288.68,
      "kickLongTermIncrementalMb90dWithSafety": 90.58,
      "projectedRows90d": {
        "twitch": 1296000,
        "kick": 432000
      },
      "reason": "One row per streamer/day/hour multiplies retained rows by up to 24 and consumes excessive storage and write volume."
    }
  },
