{
  "schemaVersion": "viewloom-12a3-generator-enablement-contract-v1",
  "workstream": "12A-3 bounded production generator enablement",
  "status": "candidate",
  "providerSeparated": true,
  "collectorEnablement": {
    "flag": "INTRADAY_GENERATION_ENABLED",
    "value": "true",
    "twitchWrangler": "workers/collector-twitch/wrangler.toml",
    "kickWrangler": "workers/collector-kick/wrangler.toml",
    "existingCron": "*/5 * * * *",
    "newCronAdded": false
  },
  "acceptanceProbe": {
    "sharedGenerator": "workers/shared/intraday-rollup.ts",
    "workerSource": "workers/analytics-generator-acceptance/src/index.ts",
    "trustedBranch": "work-analytics-12a3-enable-generator",
    "sameRepositoryOnly": true,
    "forkSecretsAllowed": false,
    "forcedMaintenanceTimeUtc": "current_utc_day_00:20",
    "generatorPasses": 2,
    "targetDays": [
      "today_utc",
      "yesterday_utc"
    ],
    "actualProductionRowsWritten": true,
    "backfillPerformed": false,
    "temporaryWorkerDeleteRequired": true,
    "temporaryServiceDeleteMethod": "Cloudflare Workers service API"
  },
  "providers": {
    "twitch": {
      "temporaryWorker": "viewloom-generator-acceptance-twitch",
      "databaseName": "vl_twitch_hot",
      "streamerCap": 600,
      "bucketMinutes": 5
    },
    "kick": {
      "temporaryWorker": "viewloom-generator-acceptance-kick",
      "databaseName": "vl_kick_hot",
      "streamerCap": 200,
      "bucketMinutes": 5
    }
  },
  "acceptance": {
    "expectedObservedDaysPerProvider": 2,
    "minimumSourceSnapshotsPerDay": 1,
    "rowsMustEqualStatusRetainedStreamers": true,
    "distinctRanksMustEqualRows": true,
    "minimumRankMustEqualOne": true,
    "maximumRankMustEqualRows": true,
    "secondPassMustMatchFirstPass": true,
    "maximumGeneratorQueriesPerPass": 12,
    "retentionCleanupMustRun": true,
    "temporaryWorkersRetained": false,
    "providerGateRequired": true
  },
  "evidence": {
    "streamerIdentitiesIncluded": false,
    "databaseIdsIncluded": false,
    "accountIdIncluded": false,
    "secretValuesIncluded": false,
    "rawResponsesIncluded": false,
    "deploymentLogsIncluded": false
  },
  "scope": {
    "collectorIndexChanged": false,
    "sharedGeneratorChanged": false,
    "migrationChanged": false,
    "webOrApiChanged": false,
    "rawRetentionChanged": false,
    "categoryCaptureIncluded": false,
    "exactSessionFieldsIncluded": false,
    "crossProviderAnalyticsIncluded": false,
    "directD1ExecuteIncluded": false
  },
  "mergeBoundary": {
    "productionAccumulationAcceptedBeforeMerge": true,
    "mainPushDeploysEnabledCollectors": true,
    "nextMaintenanceRefreshUsesExistingCron": true
  }
}
